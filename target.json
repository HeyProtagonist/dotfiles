{
  "files": [
    "$USER/.bashrc",
    "$USER/.zshrc",
    "$USER/.vimrc",
    "$USER/.viminfo",
    "$USER/AppData/Roaming/Hyper/.hyper.js",
    "$USER/AppData/Roaming/Code/User/keybindings.json",
    "$USER/AppData/Roaming/Code/User/settings.json"
  ],
  "folders": [
    "$USER/AppData/Roaming/Code/User/snippets",
    "$USER/.config"
  ],
  "shell": [
    {
      "fileName": "extensions.txt",
      "backup-script": "code --list-extensions",
      "restore-script": "code --install-extension <ext-id>"
    }
  ]
}
