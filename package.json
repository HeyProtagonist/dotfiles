  "bugs": {
    "url": "https://github.com/HeyProtagonist/dotfiles/issues"
  },
  "homepage": "https://github.com/HeyProtagonist/dotfiles#readme",
  "devDependencies": {
    "@types/node": "^22.10.3"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "prettier": "^3.4.2"
  }
}
