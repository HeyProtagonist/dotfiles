{
  "name": "dotfiles",
  "version": "1.0.0",
  "description": "Backup and Restore Configuration of VIM, BASH, Hyper, VSCode",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "backup": "node src/index.js",
    "restore": "node src/index.js --restore",
    "format": "prettier --end-of-line crlf --write ."
  },
