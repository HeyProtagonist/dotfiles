"3	LINE	0
	#!/usr/bin/env bash
	
	echo -e "IP Address\t\tMAC Address\t\tHost Name"
	echo "-------------------------------------------------------------"
	
	# Grab Windows ARP table and parse
	/c/Windows/System32/arp.exe -a | grep -E "([0-9]+\.){3}[0-9]+" | while read -r line; do
	    ip=$(echo "$line" | awk '{print $1}')
	    mac=$(echo "$line" | awk '{print $2}')
	    hostname=$(python -c "import socket; print(socket.getfqdn('$ip'))" 2>/dev/null)
	    [ -z "$hostname" ] && hostname="Unknown"
	    printf "%-16s\t%-17s\t%s\n" "$ip" "$mac" "$hostname"
	dggdoned13k
|3,0,3,1,13,0,1745079500,"#!/usr/bin/env bash","","echo -e \"IP Address\\t\\tMAC Address\\t\\tHost Name\"","echo \"-------------------------------------------------------------\"","","# Grab Windows ARP table and parse","/c/Windows/System32/arp.exe -a | grep -E \"([0-9]+\\.){3}[0-9]+\" | while read -r line; do","    ip=$(echo \"$line\" | awk '{print $1}')","    mac=$(echo \"$line\" | awk '{print $2}')",>87
|<"    hostname=$(python -c \"import socket; print(socket.getfqdn('$ip'))\" 2>/dev/null)","    [ -z \"$hostname\" ] && hostname=\"Unknown\"","    printf \"%-16s\\t%-17s\\t%s\\n\" \"$ip\" \"$mac\" \"$hostname\"","dggdoned13k"
"4	LINE	0
	#!/usr/bin/env bash
	
	# Define the subnet prefix (change based on your LAN)
	subnet="192.168.1"
	
	# Ping sweep + fill ARP cache
	for i in {1..254}; do
	    ping -c 1 -W 1 $subnet.$i > /dev/null &
	done
	wait
	
	# Show results from ARP table
	echo -e "\nIP Address\t\tMAC Address\t\tHost Name"
	echo "-------------------------------------------------------------"
	
	arp -n | grep "$subnet" | while read -r ip hwtype mac rest; do
	    hostname=$(getent hosts "$ip" | awk '{print $2}')
	    [ -z "$hostname" ] && hostname="Unknown"
	    printf "%-16s\t%-17s\t%s\n" "$ip" "$mac" "$hostname"
	done
	
